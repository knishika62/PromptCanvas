# ---------------------------------------------------------------
# Image to Prompt - app.py 設定ファイル（.env にコピーして使用）
# ---------------------------------------------------------------

# --- サーバー ---
HOST=127.0.0.1
PORT=7860

# --- PaddleOCR ---
# japan: 日英混在対応 / en: 英語のみ
IMAGE_TO_PROMPT_OCR_LANG=japan,en

# --- Vision LLM (OpenAI互換エンドポイント) ---
VISION_API_BASE=http://192.168.11.200:1234/v1
VISION_API_KEY=EMPTY
# bbox精度の高いvision対応モデルを推奨（Gemma系で良好な結果）
VISION_MODEL=gemma-4-31b-it

# 画像リサイズ上限 (短辺px) - 大きいほど精度↑・速度↓
VISION_FULL_MAX_PX=1024
VISION_CROP_MAX_PX=512

# 応答の最大トークン数 (thinking対応モデルは思考に消費するため大きめに)
# VISION_MAX_TOKENS=6000

# --- WOMAN タグ ---
# woman/girl/female/lady を "{WOMAN} woman" に統一する（例: Japanese, Korean, Chinese）
# 未設定なら補正無効
WOMAN=Japanese

# --- 開発用 ---
# モデルを読み込まずに起動する場合は 1 に設定
# IMAGE_TO_PROMPT_MOCK=1
